{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "./",
    "rootDir": "./",
    "removeComments": false,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["main.ts"],
  "exclude": ["node_modules"]
}
